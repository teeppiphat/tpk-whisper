{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tpk-whisper",
  "version": "0.1.0",
  "identifier": "ai.bedrock.tpkwhisper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": false,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "tpk-whisper — Settings",
        "width": 420,
        "height": 560,
        "resizable": false,
        "visible": false,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
