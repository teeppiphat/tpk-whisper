<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Why we need the mic. Shown in the macOS permission prompt. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>tpk-whisper records your voice while you hold the dictation hotkey, then transcribes it with Typhoon ASR.</string>

    <!-- Run as a menu-bar/agent app: no Dock icon, no main window. -->
    <key>LSUIElement</key>
    <true/>
</dict>
</plist>
